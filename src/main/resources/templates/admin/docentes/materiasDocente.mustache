<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Materias del Docente</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-purple-700">Materias del Docente</h1>
            <p class="text-gray-600 mt-2">{{nombreDocente}}</p>
        </div>
        <a href="/admin/docentes"
           class="bg-gray-700 text-white px-5 py-2 rounded-lg hover:bg-gray-800 transition">
            Volver
        </a>
    </div>

    <!-- MENSAJES -->
    {{#successMessage}}
    <div class="bg-green-100 border border-green-300 text-green-800 p-4 rounded mb-6">
        {{successMessage}}
    </div>
    {{/successMessage}}

    {{#errorMessage}}
    <div class="bg-red-100 border border-red-300 text-red-800 p-4 rounded mb-6">
        {{errorMessage}}
    </div>
    {{/errorMessage}}

    <!-- MATERIAS ASIGNADAS -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-200 p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Materias Asignadas</h2>

        {{#sinAsignaciones}}
        <p class="text-gray-400">Este docente no tiene materias asignadas.</p>
        {{/sinAsignaciones}}

        {{^sinAsignaciones}}
        <table class="min-w-full border border-gray-200">
            <thead class="bg-gray-100">
                <tr>
                    <th class="p-3 border">Materia</th>
                    <th class="p-3 border">Cargo</th>
                    <th class="p-3 border">Fecha</th>
                    <th class="p-3 border">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {{#asignaciones}}
                <tr class="hover:bg-gray-50">
                    <td class="p-3 border text-center">{{nombreMateria}}</td>
                    <td class="p-3 border text-center">{{cargo}}</td>
                    <td class="p-3 border text-center">{{fecha}}</td>
                    <td class="p-3 border text-center">
                        <form method="post" action="/admin/docentes/{{codigoProfesor}}/materias/{{id}}/delete">
                            <button type="submit"
                                    class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 transition text-sm">
                                Quitar
                            </button>
                        </form>
                    </td>
                </tr>
                {{/asignaciones}}
            </tbody>
        </table>
        {{/sinAsignaciones}}
    </div>

    <!-- AGREGAR MATERIA -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Asignar Nueva Materia</h2>

        {{#sinMaterias}}
        <p class="text-gray-400">No hay materias disponibles para asignar.</p>
        {{/sinMaterias}}

        {{^sinMaterias}}
        <form method="post" action="/admin/docentes/{{codigoProfesor}}/materias/agregar" class="space-y-4">
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Materia</label>
                <select name="cod_materia"
                        class="w-full border border-gray-300 rounded-lg p-2"
                        required>
                    <option value="">Seleccionar materia...</option>
                    {{#materiasDisponibles}}
                    <option value="{{codMateria}}">{{nombre}}</option>
                    {{/materiasDisponibles}}
                </select>
            </div>
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Cargo</label>
                <select name="cargo"
                        class="w-full border border-gray-300 rounded-lg p-2"
                        required>
                    <option value="">Seleccionar cargo...</option>
                    <option value="Responsable_de_Catedra">Responsable de Cátedra</option>
                    <option value="Jefe_de_Trabajos_Practicos">Jefe de Trabajos Prácticos</option>
                    <option value="Ayudante">Ayudante</option>
                </select>
            </div>
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Fecha</label>
                <input type="date" name="fecha"
                       class="w-full border border-gray-300 rounded-lg p-2"
                       required>
            </div>
            <button type="submit"
                    class="bg-purple-600 text-white px-6 py-2 rounded-lg hover:bg-purple-700 transition font-semibold">
                Asignar Materia
            </button>
        </form>
        {{/sinMaterias}}
    </div>

</div>
</body>
</html>
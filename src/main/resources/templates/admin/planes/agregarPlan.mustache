<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuevo Plan de Estudio</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-lg">

        <h1 class="text-2xl font-bold text-gray-800 mb-6">Nuevo Plan de Estudio</h1>

        {{#sinCarreras}}
        <div class="bg-yellow-100 border border-yellow-300 text-yellow-800 px-4 py-3 rounded mb-4">
            No hay carreras disponibles. <a href="/admin/carreras/agregar" class="underline">Crear una carrera primero.</a>
        </div>
        {{/sinCarreras}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-4">
            {{errorMessage}}
        </div>
        {{/errorMessage}}

        {{^sinCarreras}}
        <form method="post" action="/admin/planes/agregar" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Carrera *</label>
                <select name="cod_carrera"
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400"
                        required>
                    <option value="">Seleccionar carrera...</option>
                    {{#carreras}}
                    <option value="{{codCarrera}}">{{nombre}}</option>
                    {{/carreras}}
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Año *</label>
                <input type="number" name="anio"
                       class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400"
                       required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Vigencia (años) *</label>
                <input type="number" name="vigencia"
                       class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400"
                       required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Años total *</label>
                <input type="number" name="anios_total"
                       class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400"
                       required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Cantidad de materias *</label>
                <input type="number" name="cantidad_materias_total"
                       class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400"
                       required>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="bg-purple-600 text-white py-2 px-6 rounded-md hover:bg-purple-700 transition">
                    Crear Plan
                </button>
                <a href="/admin/planes"
                   class="bg-gray-200 text-gray-700 py-2 px-6 rounded-md hover:bg-gray-300 transition">
                    Cancelar
                </a>
            </div>
        </form>
        {{/sinCarreras}}

    </div>
</body>
</html>
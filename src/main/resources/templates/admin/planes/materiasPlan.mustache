<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Materias del Plan</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Materias del Plan</h1>
            <p class="text-gray-500 mt-1">
                Carrera: <span class="font-medium text-gray-700">{{nombreCarrera}}</span> —
                Año: <span class="font-medium text-gray-700">{{anio}}</span> —
                Vigencia: <span class="font-medium text-gray-700">{{vigencia}}</span>
            </p>
        </div>

        {{#sinMaterias}}
        <div class="bg-yellow-100 border border-yellow-300 text-yellow-800 px-4 py-3 rounded mb-4">
            Este plan no tiene materias asociadas.
        </div>
        {{/sinMaterias}}

        {{^sinMaterias}}
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Código</th>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Nombre</th>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Descripción</th>
                    </tr>
                </thead>
                <tbody>
                    {{#materias}}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-6 py-4 text-gray-700">{{codMateria}}</td>
                        <td class="px-6 py-4 font-medium text-gray-800">{{nombre}}</td>
                        <td class="px-6 py-4 text-gray-600">{{descripcion}}</td>
                    </tr>
                    {{/materias}}
                </tbody>
            </table>
        </div>
        {{/sinMaterias}}

        <div class="mt-4">
            <a href="/admin/planes" class="text-gray-500 hover:text-gray-700 transition">← Volver a planes</a>
        </div>

    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Eliminar Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-lg">

    <h1 class="text-2xl font-bold text-gray-800 mb-6">Eliminar Materia</h1>

    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6 space-y-2">
        <p><span class="font-medium text-gray-600">Código:</span> {{codMateria}}</p>
        <p><span class="font-medium text-gray-600">Nombre:</span> {{nombre}}</p>
        <p><span class="font-medium text-gray-600">Descripción:</span> {{descripcion}}</p>
    </div>

    <p class="text-gray-700 mb-6">¿Estás seguro que querés eliminar esta materia? Esta acción no se puede deshacer.</p>

    <form method="post" action="/admin/materias/{{codMateria}}/delete" class="flex gap-3">
        <button type="submit"
                class="bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition">
            Confirmar Eliminación
        </button>
        <a href="/admin/materias"
           class="bg-gray-200 text-gray-700 py-2 px-6 rounded-md hover:bg-gray-300 transition">
            Cancelar
        </a>
    </form>

</div>
</body>
</html>

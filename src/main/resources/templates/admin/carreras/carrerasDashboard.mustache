<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carreras</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
    <div class="max-w-4xl mx-auto">

        <div class="flex items-center justify-between mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Carreras</h1>
            <a href="/admin/carreras/agregar"
               class="bg-purple-600 text-white py-2 px-4 rounded-md hover:bg-purple-700 transition">
                + Nueva Carrera
            </a>
        </div>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded mb-4">
            {{successMessage}}
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-4">
            {{errorMessage}}
        </div>
        {{/errorMessage}}

        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Código</th>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Nombre</th>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Descripción</th>
                        <th class="px-6 py-3 text-gray-600 font-semibold">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#carreras}}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-6 py-4 text-gray-700">{{codCarrera}}</td>
                        <td class="px-6 py-4 font-medium text-gray-800">{{nombre}}</td>
                        <td class="px-6 py-4 text-gray-600">{{descripcion}}</td>
                        <td class="px-6 py-4 flex gap-2">
                            <a href="/admin/carreras/{{codCarrera}}/edit"
                               class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 transition text-sm">
                                Editar
                            </a>
                            <a href="/admin/carreras/{{codCarrera}}/delete"
                               class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 transition text-sm">
                                Eliminar
                            </a>
                        </td>
                    </tr>
                    {{/carreras}}
                    {{^carreras}}
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-gray-400">
                            No hay carreras registradas.
                        </td>
                    </tr>
                    {{/carreras}}
                </tbody>
            </table>
        </div>

        <div class="mt-4">
            <a href="/admin" class="text-gray-500 hover:text-gray-700 transition">← Volver al panel</a>
        </div>

    </div>
</body>
</html>
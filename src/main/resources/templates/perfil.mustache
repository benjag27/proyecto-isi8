<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Mi Perfil</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen p-6">

<div class="max-w-5xl mx-auto">

    <!-- CABECERA -->

    <div class="mb-8 text-center">
        <h1 class="text-4xl font-bold text-gray-800 mb-2">
            Mi Perfil
        </h1>

        <p class="text-gray-600">
            Consulta la información asociada a tu cuenta.
        </p>
    </div>

    <!-- DATOS GENERALES -->

    <!-- ADMINISTRADOR -->

    {{#esAdmin}}

    <div class="bg-purple-50 border border-purple-200 p-6 rounded-lg shadow-sm mb-6">

        <h2 class="text-xl font-bold text-purple-700 mb-4">
            Información de la Cuenta
        </h2>

        <div class="grid md:grid-cols-2 gap-4 mb-6">

            <div class="bg-purple-100 p-4 rounded-lg border border-purple-200">
                <strong>Usuario:</strong> {{usuario.name}}
            </div>

            <div class="bg-purple-100 p-4 rounded-lg border border-purple-200">
                <strong>Rol:</strong> {{usuario.rol}}
            </div>

        </div>

        <hr class="mb-6">

        <h2 class="text-xl font-bold text-purple-700 mb-4">
            Información Personal
        </h2>

        <div class="bg-purple-100 p-4 rounded-lg border border-purple-200">
            Este usuario posee permisos administrativos sobre el sistema.
        </div>

    </div>

    {{/esAdmin}}

    <!-- DOCENTE -->

    {{#esDocente}}

    <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg shadow-sm mb-6">

        <h2 class="text-xl font-bold text-blue-700 mb-4">
            Información de la Cuenta
        </h2>

        <div class="grid md:grid-cols-2 gap-4 mb-6">

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Usuario:</strong> {{usuario.name}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Rol:</strong> {{usuario.rol}}
            </div>

        </div>

        <hr class="mb-6">

        <h2 class="text-xl font-bold text-blue-700 mb-4">
            Información Personal
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Nombre:</strong> {{persona.nombre}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Apellido:</strong> {{persona.apellido}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>DNI:</strong> {{persona.dni}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Email:</strong> {{docente.email}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Teléfono:</strong> {{persona.telefono}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Dirección:</strong> {{persona.direccion}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Fecha de Nacimiento:</strong> {{persona.fechaNacimiento}}
            </div>

            <div class="bg-blue-100 p-4 rounded-lg border border-blue-200">
                <strong>Código de Profesor:</strong> {{docente.codigoProfesor}}
            </div>

        </div>

    </div>

    {{/esDocente}}

    <!-- ALUMNO -->

    {{#esAlumno}}

    <div class="bg-green-50 border border-green-200 p-6 rounded-lg shadow-sm mb-6">

        <h2 class="text-xl font-bold text-green-700 mb-4">
            Información de la Cuenta
        </h2>

        <div class="grid md:grid-cols-2 gap-4 mb-6">

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Usuario:</strong> {{usuario.name}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Rol:</strong> {{usuario.rol}}
            </div>

        </div>

        <hr class="mb-6">

        <h2 class="text-xl font-bold text-green-700 mb-4">
            Información Personal
        </h2>

        <div class="grid md:grid-cols-2 gap-4">

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Nombre:</strong> {{persona.nombre}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Apellido:</strong> {{persona.apellido}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>DNI:</strong> {{persona.dni}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Email:</strong> {{estudiante.email}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Legajo:</strong> {{estudiante.nroLegajo}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Teléfono:</strong> {{persona.telefono}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Dirección:</strong> {{persona.direccion}}
            </div>

            <div class="bg-green-100 p-4 rounded-lg border border-green-200">
                <strong>Fecha de Nacimiento:</strong> {{persona.fechaNacimiento}}
            </div>

        </div>

    </div>

    {{/esAlumno}}

    <!-- BOTONES -->

    <div class="flex gap-4 justify-center">

        <button
            disabled
            class="bg-yellow-500 text-white py-2 px-5 rounded-md opacity-50 cursor-not-allowed">
            Cambiar Contraseña
        </button>

        <a href="/dashboard"
           class="bg-green-600 text-white py-2 px-5 rounded-md hover:bg-green-700 transition duration-300">
            Volver al Dashboard
        </a>

    </div>

</div>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl">

        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">
            Panel de Control
        </h1>

        <!-- Rol del usuario -->
        <div class="text-center mb-6">
            <span class="inline-block text-sm font-semibold px-4 py-2 rounded-full {{rolClass}}">
                {{rol}}
            </span>
        </div>
        

        <!-- Bienvenida -->
        <p class="text-xl text-center text-gray-700 mb-8">
            ¡Bienvenido,
            <span class="font-semibold text-blue-600">
                {{username}}
            </span>!
        </p>

        <!-- Mensaje de Error -->
        {{#errorMessage}}
        <div class="mb-6 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg shadow-sm">
            <div class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 mr-2"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4m0 4h.01M10.29 3.86l-7.82 13.5A2 2 0 004.18 20h15.64a2 2 0 001.71-2.64l-7.82-13.5a2 2 0 00-3.42 0z"/>
                </svg>

                <span>{{errorMessage}}</span>
            </div>
        </div>
        {{/errorMessage}}
        
        <!-- Tarjetas -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

            <!-- Perfil -->
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-xl font-bold text-green-700 mb-3">
                    Tu Perfil
                </h2>

                <p class="text-gray-600 mb-4">
                    Gestiona la información de tu cuenta.
                </p>

                <a href="/profile"
                   class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">
                    Ver Perfil
                </a>
            </div>

            <!-- Configuración -->
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">

                <h2 class="text-xl font-bold text-blue-700 mb-3">
                    Configuración
                </h2>

                <p class="text-gray-600 mb-4">
                    Ajusta las preferencias de tu aplicación.
                </p>

                <a href="/settings"
                   class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">
                    Configuración
                </a>
            </div>

            <!-- Solo Admin -->
            {{#isAdmin}}
            <div class="bg-purple-50 border border-purple-200 p-6 rounded-lg text-center shadow-sm">

                <h2 class="text-xl font-bold text-purple-700 mb-3">
                    Administración
                </h2>

                <p class="text-gray-600 mb-4">
                    Gestiona carreras, materias, docentes, estudiantes y planes.
                </p>

                <a href="/admin"
                class="inline-block bg-purple-600 text-white py-2 px-4 rounded-md hover:bg-purple-700 transition duration-300">
                    Abrir Panel
                </a>
            </div>
            {{/isAdmin}}

        </div>

        <!-- Logout -->
        <div class="text-center mt-6">
            <a href="/logout"
               class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">
                Cerrar Sesión
            </a>
        </div>

    </div>

</body>
</html>
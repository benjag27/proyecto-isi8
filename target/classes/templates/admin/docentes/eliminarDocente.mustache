<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Eliminar Docente</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

    <div class="bg-white shadow-lg rounded-xl p-8 w-full max-w-lg">

        <h1 class="text-3xl font-bold text-red-600 mb-6 text-center">
            Confirmar Eliminación
        </h1>

        <div class="bg-red-100 border border-red-300 text-red-800 p-4 rounded mb-6">

            <p class="font-semibold mb-2">
                ¿Seguro que deseas eliminar este docente?
            </p>

            <ul class="space-y-1">
                <li><strong>DNI:</strong> {{dni}}</li>
                <li><strong>Nombre:</strong> {{nombre}}</li>
                <li><strong>Apellido:</strong> {{apellido}}</li>
                <li><strong>Email:</strong> {{email}}</li>
                <li><strong>Usuario:</strong> {{username}}</li>
            </ul>

        </div>

        <form
            action="/admin/docentes/{{codigoProfesor}}/delete"
            method="post"
            class="flex justify-between"
        >

            <a
                href="/admin/docentes"
                class="bg-gray-500 hover:bg-gray-600 text-white px-5 py-2 rounded-lg"
            >
                Cancelar
            </a>

            <button
                type="submit"
                class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg"
            >
                Sí, eliminar
            </button>

        </form>

    </div>

</body>
</html>
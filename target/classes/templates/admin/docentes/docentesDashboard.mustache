<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración de Docentes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen p-6">

<div class="max-w-7xl mx-auto">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-4xl font-bold text-purple-700">
                Administración de Docentes
            </h1>
            <p class="text-gray-600 mt-2">
                Gestiona docentes del sistema.
            </p>
        </div>
        <a href="/admin"
           class="bg-gray-700 text-white px-5 py-2 rounded-lg hover:bg-gray-800 transition">
            Volver
        </a>
    </div>

    <!-- MENSAJES -->
    {{#successMessage}}
    <div class="bg-green-100 border border-green-300 text-green-800 p-4 rounded mb-6">
        {{successMessage}}
    </div>
    {{/successMessage}}

    {{#errorMessage}}
    <div class="bg-red-100 border border-red-300 text-red-800 p-4 rounded mb-6">
        {{errorMessage}}
    </div>
    {{/errorMessage}}

    <!-- ACCIONES CRUD -->
    <div class="flex flex-wrap gap-3 mb-8">
        <!-- CREAR -->
        <a href="/admin/docentes/agregar"
           class="bg-green-600 text-white px-5 py-2 rounded-lg hover:bg-green-700 transition font-semibold">
            Registrar Docente
        </a>

        <!-- LEER -->
        <a href="/admin/docentes/listado"
        target="_blank"
        class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition font-semibold">
            Vista Detallada
        </a>
    </div>

    <!-- TABLA -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-200 p-6">

        <h2 class="text-2xl font-bold text-gray-800 mb-6">
            Listado de Docentes
        </h2>

        <!-- FILTROS -->
        <div class="flex gap-3 mb-6">

            <input
                type="text"
                id="filtroDni"
                placeholder="Buscar por DNI..."
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"
                oninput="filtrar()"
            />

            <input
                type="text"
                id="filtroNombre"
                placeholder="Buscar por nombre..."
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"
                oninput="filtrar()"
            />

            <input
                type="text"
                id="filtroApellido"
                placeholder="Buscar por apellido..."
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"
                oninput="filtrar()"
            />

        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200">

                <thead class="bg-gray-100">
                    <tr>
                        <th class="p-3 border">ID</th>
                        <th class="p-3 border">DNI</th>
                        <th class="p-3 border">Nombre</th>
                        <th class="p-3 border">Apellido</th>
                        <th class="p-3 border">Email</th>
                        <th class="p-3 border">Usuario</th>
                        <th class="p-3 border">Acciones</th>
                    </tr>
                </thead>

                <tbody id="tablaDocentes">
                    {{#docentes}}
                    <tr class="hover:bg-gray-50 fila-docente">
                        <td class="p-3 border text-center">{{id}}</td>
                        <td class="p-3 border text-center dni">{{dni}}</td>
                        <td class="p-3 border text-center nombre">{{nombre}}</td>
                        <td class="p-3 border text-center apellido">{{apellido}}</td>
                        <td class="p-3 border text-center">{{email}}</td>
                        <td class="p-3 border text-center">{{username}}</td>
                        <td class="p-3 border text-center">
                            <div class="flex justify-center gap-2">
                                <a href="/admin/docentes/{{id}}/materias"
                                   class="bg-purple-500 text-white px-3 py-1 rounded hover:bg-purple-600 transition text-sm">
                                    Materias
                                </a>
                                <a href="/admin/docentes/{{id}}/edit"
                                   class="bg-yellow-500 text-white px-3 py-1 rounded hover:bg-yellow-600 transition text-sm">
                                    Editar
                                </a>
                                <a href="/admin/docentes/{{id}}/delete"
                                   class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm">
                                    Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                    {{/docentes}}
                </tbody>

            </table>

            <div id="sinResultados" class="hidden text-center py-6 text-gray-400 text-sm">
                No se encontraron docentes.
            </div>

        </div>

    </div>

</div>

<script>
    function filtrar() {

        // obtengo lo que escribió el usuario en cada campo
        var dni      = document.getElementById('filtroDni').value.toLowerCase();
        var nombre   = document.getElementById('filtroNombre').value.toLowerCase();
        var apellido = document.getElementById('filtroApellido').value.toLowerCase();

        // obtengo todas las filas de la tabla
        var filas = document.querySelectorAll('.fila-docente');

        var visibles = 0;

        // recorro cada fila
        for (var i = 0; i < filas.length; i++) {

            var fila = filas[i];

            // obtengo el texto de cada celda
            var textoDni      = fila.querySelector('.dni').textContent.toLowerCase();
            var textoNombre   = fila.querySelector('.nombre').textContent.toLowerCase();
            var textoApellido = fila.querySelector('.apellido').textContent.toLowerCase();

            // verifico si la fila coincide con los filtros
            var coincideDni      = textoDni.includes(dni);
            var coincideNombre   = textoNombre.includes(nombre);
            var coincideApellido = textoApellido.includes(apellido);

            // si coincide con todos los filtros la muestro, sino la oculto
            if (coincideDni && coincideNombre && coincideApellido) {
                fila.style.display = '';
                visibles++;
            } else {
                fila.style.display = 'none';
            }

        }

        // muestro mensaje si no hay resultados
        if (visibles === 0) {
            document.getElementById('sinResultados').classList.remove('hidden');
        } else {
            document.getElementById('sinResultados').classList.add('hidden');
        }

    }
</script>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Agregar Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">

    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-blue-700">Nueva Materia</h1>
        <a href="/admin/materias" class="bg-gray-700 text-white px-5 py-2 rounded-lg hover:bg-gray-800 transition">
            Volver
        </a>
    </div>

    {{#errorMessage}}
    <div class="bg-red-100 border border-red-300 text-red-800 p-4 rounded mb-6">{{errorMessage}}</div>
    {{/errorMessage}}

    {{#sinPlanes}}
    <div class="bg-yellow-100 border border-yellow-300 text-yellow-800 p-4 rounded mb-6">
        No hay planes de estudio. <a href="/admin/planes/agregar" class="underline">Crear un plan primero.</a>
    </div>
    {{/sinPlanes}}

    {{^sinPlanes}}
    <div class="bg-white p-8 rounded-2xl shadow-md">
        <form action="/admin/materias/agregar" method="POST" class="space-y-4">
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Nombre *</label>
                <input type="text" name="nombre"
                       class="w-full border border-gray-300 rounded-lg p-2" required>
            </div>
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Codigo *</label>
                <input type="text" name="cod_materia"
                       class="w-full border border-gray-300 rounded-lg p-2" required>
            </div>
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Descripción</label>
                <textarea name="descripcion" rows="3"
                          class="w-full border border-gray-300 rounded-lg p-2"></textarea>
            </div>
            <div>
                <label class="block text-gray-700 font-semibold mb-2">Plan de Estudios *</label>
                <select name="cod_plan" class="w-full border border-gray-300 rounded-lg p-2" required>
                    <option value="">Seleccionar plan...</option>
                    {{#planes}}
                    <option value="{{codPlan}}">{{nombrePlan}}</option>
                    {{/planes}}
                </select>
            </div>
            <button type="submit"
                    class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition font-semibold">
                Crear Materia
            </button>
        </form>
    </div>
    {{/sinPlanes}}

</div>
</body>
</html>

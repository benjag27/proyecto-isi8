<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Listado de Estudiantes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-6">

<div class="max-w-7xl mx-auto">

    <h1 class="text-3xl font-bold text-red-700 mb-6">
        Listado de Estudiantes
    </h1>

    <div class="bg-white rounded-xl shadow-md p-6">

        <table class="min-w-full border border-gray-200">

            <thead class="bg-gray-100">
                <tr>
                    <th class="p-3 border">Numero de Legajo</th>
                    <th class="p-3 border">DNI</th>
                    <th class="p-3 border">Nombre</th>
                    <th class="p-3 border">Apellido</th>
                    <th class="p-3 border">Telefono</th>
                    <th class="p-3 border">Direccion</th>
                    <th class="p-3 border">Fecha de Nacimiento</th>
                    <th class="p-3 border">Email</th>
                    <th class="p-3 border">Usuario</th>
                </tr>
            </thead>

            <tbody>

                {{#estudiantes}}
                <tr class="hover:bg-gray-50">

                    <td class="p-3 border text-center">
                        {{id}}
                    </td>

                    <td class="p-3 border text-center">
                        {{dni}}
                    </td>

                    <td class="p-3 border text-center">
                        {{nombre}}
                    </td>

                    <td class="p-3 border text-center">
                        {{apellido}}
                    </td>

                    <td class="p-3 border text-center">
                        {{telefono}}
                    </td>

                    <td class="p-3 border text-center">
                        {{direccion}}
                    </td>

                    <td class="p-3 border text-center">
                        {{fecha_nacimiento}}
                    </td>

                    <td class="p-3 border text-center">
                        {{email}}
                    </td>

                    <td class="p-3 border text-center">
                        {{username}}
                    </td>

                </tr>
                {{/estudiantes}}

            </tbody>

        </table>

    </div>

</div>

</body>
</html>